{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://scan.moukaeritai.work/schema/source-packet.schema.json",
  "title": "Source Packet Schema",
  "description": "Validation schema for source packet manifest",
  "type": "object",
  "required": [
    "formatVersion",
    "packetId",
    "purpose",
    "source",
    "destination",
    "files",
    "ownerDecisions"
  ],
  "properties": {
    "formatVersion": { "const": "1.0" },
    "packetId": { "$ref": "#/definitions/nonBlankString" },
    "purpose": { "$ref": "#/definitions/nonBlankString" },
    "source": { "$ref": "#/definitions/sourceDescriptor" },
    "destination": { "$ref": "#/definitions/destinationDescriptor" },
    "files": {
      "type": "array",
      "items": { "$ref": "#/definitions/fileEntry" }
    },
    "ownerDecisions": {
      "type": "array",
      "items": { "$ref": "#/definitions/ownerDecision" }
    }
  },
  "definitions": {
    "nonBlankString": {
      "type": "string",
      "pattern": "^.*[^\\s].*$"
    },
    "fullCommitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "safeRelativePath": {
      "type": "string",
      "pattern": "^(?!\\s*$)(?!.*\\x00)(?!^/)(?!^[a-zA-Z]:(?:/|\\\\))(?!^\\\\\\\\)(?!(?:^|.*(?:/|\\\\))(?:\\.\\.?)(?:/|\\\\|$)).*$"
    },
    "sourceDescriptor": {
      "type": "object",
      "required": ["repository", "commit"],
      "properties": {
        "repository": { "$ref": "#/definitions/nonBlankString" },
        "commit": { "$ref": "#/definitions/fullCommitSha" }
      },
      "additionalProperties": false
    },
    "destinationDescriptor": {
      "type": "object",
      "required": ["repository", "baselineCommit"],
      "properties": {
        "repository": { "const": "TakashiSasaki/scan3" },
        "baselineCommit": { "$ref": "#/definitions/fullCommitSha" }
      },
      "additionalProperties": false
    },
    "fileEntry": {
      "type": "object",
      "required": ["sourcePath", "payloadPath", "sha256", "sizeBytes", "disposition"],
      "properties": {
        "sourcePath": { "$ref": "#/definitions/safeRelativePath" },
        "payloadPath": { "$ref": "#/definitions/safeRelativePath" },
        "sha256": { "$ref": "#/definitions/sha256" },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "disposition": {
          "type": "string",
          "enum": ["restore", "reference", "exclude"]
        },
        "intendedDestination": {
          "anyOf": [
            { "$ref": "#/definitions/safeRelativePath" },
            { "type": "null" }
          ]
        },
        "notes": { "type": "string" }
      },
      "if": {
        "properties": { "disposition": { "const": "restore" } }
      },
      "then": {
        "required": ["intendedDestination"],
        "properties": {
          "intendedDestination": { "type": "string" }
        }
      }
    },
    "ownerDecision": {
      "type": "object",
      "required": ["id", "value", "reason"],
      "properties": {
        "id": { "$ref": "#/definitions/nonBlankString" },
        "value": {},
        "reason": { "$ref": "#/definitions/nonBlankString" }
      },
      "additionalProperties": false
    }
  }
}
