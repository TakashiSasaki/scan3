[
  {
    "name": "source-packet-path-helper",
    "runner": "scripts/test-source-packet-path-helper.cjs",
    "constraintIds": [
      "C-PATH-RAW"
    ],
    "cases": [
      {
        "name": "nul-character",
        "input": "file\u0000.txt",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "absolute-posix-path",
        "input": "/etc/passwd",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "windows-drive-path-backslash",
        "input": "C:\\Windows\\System32",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "windows-drive-path-slash",
        "input": "C:/Windows/System32",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "unc-path",
        "input": "\\\\server\\share\\file.txt",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "dot-segment-middle",
        "input": "a/./b.txt",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "dot-segment-alone",
        "input": ".",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "dot-dot-segment-middle",
        "input": "a/../b.txt",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "dot-dot-segment-alone",
        "input": "..",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "whitespace-only-path",
        "input": "   ",
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "non-string-input",
        "input": 12345,
        "fieldName": "payloadPath",
        "expectedOutcome": "ERROR",
        "expectedErrorCode": "PATH_INVALID"
      },
      {
        "name": "valid-dotted-filename",
        "input": "archive.tar.gz",
        "fieldName": "payloadPath",
        "expectedOutcome": "PASS"
      },
      {
        "name": "valid-nested-dotted-filename",
        "input": "directory.name/file.name.txt",
        "fieldName": "payloadPath",
        "expectedOutcome": "PASS"
      }
    ]
  }
]
